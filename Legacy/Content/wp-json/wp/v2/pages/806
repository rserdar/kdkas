w.tekinasasansor.com\/wp-content\/uploads\/2024\/08\/97d1662a-400x300.webp\" class=\"attachment-blog-grid-small size-blog-grid-small\" alt=\"\" \/><\/figure><figure><img decoding=\"async\" width=\"400\" height=\"300\" src=\"https:\/\/www.tekinasasansor.com\/wp-content\/uploads\/2024\/08\/fe4a3d48-400x300.webp\" class=\"attachment-blog-grid-small size-blog-grid-small\" alt=\"\" \/><\/figure><\/div>\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-4a86b09 elementor-widget elementor-widget-heading\" data-id=\"4a86b09\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t<style>\/*! elementor - v3.23.0 - 25-07-2024 *\/\n.elementor-heading-title{padding:0;margin:0;line-height:1}.elementor-widget-heading .elementor-heading-title[class*=elementor-size-]>a{color:inherit;font-size:inherit;line-height:inherit}.elementor-widget-heading .elementor-heading-title.elementor-size-small{font-size:15px}.elementor-widget-heading .elementor-heading-title.elementor-size-medium{font-size:19px}.elementor-widget-heading .elementor-heading-title.elementor-size-large{font-size:29px}.elementor-widget-heading .elementor-heading-title.elementor-size-xl{font-size:39px}.elementor-widget-heading .elementor-heading-title.elementor-size-xxl{font-size:59px}<\/style><h2 class=\"elementor-heading-title elementor-size-default\">Engelli Platformlar\u0131<\/h2>\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-f7ac2bd elementor-widget elementor-widget-text-editor\" data-id=\"f7ac2bd\" data-element_type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t<style>\/*! elementor - v3.23.0 - 25-07-2024 *\/\n.elementor-widget-text-editor.elementor-drop-cap-view-stacked .elementor-drop-cap{background-color:#69727d;color:#fff}.elementor-widget-text-editor.elementor-drop-cap-view-framed .elementor-drop-cap{color:#69727d;border:3px solid;background-color:transparent}.elementor-widget-text-editor:not(.elementor-drop-cap-view-default) .elementor-drop-cap{margin-top:8px}.elementor-widget-text-editor:not(.elementor-drop-cap-view-default) .elementor-drop-cap-letter{width:1em;height:1em}.elementor-widget-text-editor .elementor-drop-cap{float:left;text-align:center;line-height:1;font-size:50px}.elementor-widget-text-editor .elementor-drop-cap-letter{display:inline-block}<\/style>\t\t\t\t<p>Engelli platformlar\u0131, engelli ki\u015filerin merdivenleri veya benzeri y\u00fckseltileri kolayca a\u015fabilmeleri i\u00e7in, merdiven \u015feklinde ya da platform \u015feklinde \u00fcretilmektedir. \u0130\u00e7 ve d\u0131\u015f mekan tasar\u0131m\u0131 m\u00fcmk\u00fcn olan bu platformlar modern mimariye uygun sistemlerdir.<\/p><p>\u00dcst ge\u00e7itler, metro, okul, hastane, camii, k\u00fclt\u00fcr merkezi, \u00f6zel konut, otel, al\u0131\u015fveri\u015f merkezi, kamu kurumlan, asans\u00f6r i\u00e7in haz\u0131rlanm\u0131\u015f bir kuyusu bulunmayan sonradan asans\u00f6r yap\u0131lmas\u0131 gereken yap\u0131larda, binalara giri\u015f ve \u00e7\u0131k\u0131\u015f\u0131n eri\u015filebilirli\u011fe uygun planlanmad\u0131\u011f\u0131 alanlarda, merdiven tipi engelli asans\u00f6r\u00fc ya da dikey tip engelli asans\u00f6r\u00fc, herkesin kolayl\u0131kla bir yerden bir yere eri\u015fimine olanak sa\u011flar.<\/p><p>Genellikle 2 duraktan 8 dura\u011fa kadar olan yerlerde g\u00fcvenlikle kullan\u0131lan engelli platformlar\u0131, uygulan\u0131ld\u0131\u011f\u0131 yap\u0131ya estetik ve zengin bir g\u00f6r\u00fcn\u00fcm sa\u011flar. \u0130\u00e7 mek\u00e2n ve d\u0131\u015f mek\u00e2nda rahatl\u0131kla uygulanabilen engelli platformlar\u0131, elektrostatik boyal\u0131 sac, krom kaplama, 4+4 lamine cam veya panel kaplamas\u0131yla nem, ya\u011fmur, kar ve rutubetten etkilenmez. Kuyu dibi gerektirmeyen ve mod\u00fcler tasar\u0131m\u0131 sayesinde minimum in\u015faat maliyeti ile ekonomik bir sistemdir.<\/p><p>Engelli platformlar\u0131, kontrol paneli ve d\u00fc\u011fmeleri, tekerlekli sandalye kullan\u0131c\u0131lar\u0131 ve g\u00f6rme engelli dahil olmak \u00fczere herhangi bir yolcu kategorisi taraf\u0131ndan kullan\u0131lmak \u00fczere tasarlanm\u0131\u015ft\u0131r. Hidrolik ve sonsuz vidal\u0131 olarak imal edilmektedir. Sonsuz vida ve hidrolik olmas\u0131 sebebiyle sessiz ve uzun s\u00fcreli kullan\u0131ma uygundur.<\/p><p>\u0130lgili Standartlar; 2006\/42\/EC Makine Direktifi ve EN 81-41:2010 Avrupa standartlar\u0131<\/p>\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t","protected":false},"excerpt":{"rendered":"<p>Engelli Platformlar\u0131 Engelli platformlar\u0131, engelli ki\u015filerin merdivenleri veya benzeri y\u00fckseltileri kolayca a\u015fabilmeleri i\u00e7in, merdiven \u015feklinde ya da platform \u015feklinde \u00fcretilmektedir. \u0130\u00e7 ve d\u0131\u015f mekan tasar\u0131m\u0131 m\u00fcmk\u00fcn olan bu platformlar modern mimariye uygun sistemlerdir. \u00dcst ge\u00e7itler, metro, okul, hastane, camii, k\u00fclt\u00fcr merkezi, \u00f6zel konut, otel, al\u0131\u015fveri\u015f merkezi, kamu kurumlan, asans\u00f6r i\u00e7in haz\u0131rlanm\u0131\u015f bir kuyusu bulunmayan sonradan [&hellip;]<\/p>\n","protected":false},"author":1,"featured_media":0,"parent":755,"menu_order":0,"comment_status":"closed","ping_status":"closed","template":"","meta":{"_acf_changed":false,"footnotes":""},"class_list":["post-806","page","type-page","status-publish","hentry"],"acf":[],"_links":{"self":[{"href":"https:\/\/www.tekinasasansor.com\/wp-json\/wp\/v2\/pages\/806","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/www.tekinasasansor.com\/wp-json\/wp\/v2\/pages"}],"about":[{"href":"https:\/\/www.tekinasasansor.com\/wp-json\/wp\/v2\/types\/page"}],"author":[{"embeddable":true,"href":"https:\/\/www.tekinasasansor.com\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"https:\/\/www.tek