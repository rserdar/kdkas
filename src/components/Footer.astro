---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import footerLogoImg from '../assets/images/logo/kdk-logo.webp';

const currentYear = new Date().getFullYear();
---

<footer class="bg-[#1c2023] text-[#aab1b7] pt-16 pb-8 font-sans border-t-4 border-primary">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1fr_1.8fr_1.4fr_1.4fr] gap-8 lg:gap-10 mb-12">

      <!-- Sütun 1: Logo -->
      <div class="flex items-start justify-center md:justify-start">
        <a href="/" class="block">
          <Image
            src={footerLogoImg}
            alt="KDK Asansör"
            class="w-full max-w-[200px] brightness-0 invert opacity-85 hover:opacity-100 transition-opacity"
          />
        </a>
      </div>

      <!-- Sütun 2: Hakkımızda -->
      <div class="space-y-6">
        <h3 class="text-white text-lg font-bold">KDK Asansör</h3>
        <p class="text-[13px] text-justify leading-relaxed text-[#999]">
          Balıkesir ve Edremit bölgesinde 20 yılı aşkın deneyimimizle asansör montaj, bakım, onarım ve revizyon hizmetleri sunuyoruz. Güvenlik, kalite ve müşteri memnuniyeti odağımızdır.
        </p>
      </div>

      <!-- Sütun 3: İletişim -->
      <div class="space-y-4">
        <h3 class="text-white text-lg font-bold">İletişim</h3>
        <ul class="space-y-4 text-[13px]">
          <li class="flex items-start gap-3">
            <Icon name="mdi:map-marker" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
            <span>Eroğlan Mah. 257 Sok. Taşkın Apt. No:2A Edremit / Balıkesir</span>
          </li>
          <li class="flex items-center gap-3">
            <Icon name="mdi:phone-outline" class="w-5 h-5 text-primary shrink-0" />
            <a href="tel:+905372234382" class="hover:text-white transition-colors">0 537 223 43 82</a>
          </li>
          <li class="flex items-center gap-3">
            <Icon name="mdi:email-outline" class="w-5 h-5 text-primary shrink-0" />
            <a href="mailto:info@kdkasansor.com" class="hover:text-white transition-colors">info@kdkasansor.com</a>
          </li>
        </ul>
      </div>

      <!-- Sütun 4: Hizmetler -->
      <div class="space-y-4">
        <h3 class="text-white text-lg font-bold">Hizmetlerimiz</h3>
        <ul class="space-y-3 text-[13px]">
          {[
            { name: 'Makine Daireli Asansörler', href: '/asansor-tipleri/makine-daireli-asansorler/' },
            { name: 'MRL Asansör', href: '/asansor-tipleri/makine-dairesiz-mrl-asansor/' },
            { name: 'Hidrolik Asansör', href: '/asansor-tipleri/hidrolik-asansor/' },
            { name: 'Montaj Hizmetleri', href: '/servisler/montaj-hizmetleri/' },
            { name: 'Bakım & Onarım', href: '/servisler/bakim-onarim-hizmetleri/' },
            { name: 'Revizyon Hizmetleri', href: '/servisler/revizyon-hizmetleri/' },
          ].map((link) => (
            <li>
              <a href={link.href} class="hover:text-white transition-colors flex items-center gap-2">
                <Icon name="mdi:chevron-right" class="w-4 h-4 text-primary" />
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Alt Çizgi -->
    <div class="border-t border-gray-700/30 pt-6 mt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-[#777] text-center sm:text-left">
        © {currentYear} KDK Asansör Ali Şentürk. Tüm hakları saklıdır.
      </p>
      <p class="text-xs text-[#999]">
        Designed by <a href="https://www.serdaryavuz.com" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors"><span class="font-bold italic">Šarić</span></a>
      </p>
    </div>
  </div>
</footer>
