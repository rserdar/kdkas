---
import { Image } from 'astro:assets';
import logoImg from '../assets/images/logo/kdk-logo.webp';
import ThemeToggle from './ThemeToggle.astro';
import SearchOverlay from './SearchOverlay.astro';
---

<header 
  id="main-header" 
  class="fixed top-5 left-0 right-0 z-50 w-full bg-white transition-all duration-500 ease-in-out border-b border-slate-100 dark:bg-slate-950 dark:border-slate-800 shadow-sm"
>
  <div class="w-full">
    <div id="header-inner" class="container mx-auto px-4 h-24 flex items-center justify-between transition-all duration-500 ease-in-out">
      <div class="logo">
        <a href="/">
          <Image id="header-logo" src={logoImg} alt="KDK Asansör" class="h-14 w-auto object-contain transition-all duration-500 ease-in-out" />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center justify-end w-full">
        <nav>
          <ul class="flex items-center space-x-8 font-bold text-[14px] uppercase tracking-wider text-dark-2">
            <li><a href="/" class="py-4 transition-colors hover:text-primary">Anasayfa</a></li>
            <li><a href="/hakkimizda/" class="py-4 transition-colors hover:text-primary">Hakkımızda</a></li>
            <li class="group relative">
              <a href="/hizmetlerimiz/" class="flex items-center py-4 transition-colors group-hover:text-primary">
                Hizmetlerimiz
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
              </a>
              <div class="absolute top-full left-1/2 z-50 hidden w-[850px] -translate-x-1/2 border-t-4 border-primary bg-white p-8 shadow-2xl ring-1 ring-black/5 group-hover:block dark:bg-slate-900">
                <div class="grid grid-cols-3 gap-8">
                  <div>
                    <h3 class="mb-4 border-b border-slate-100 pb-2 text-[15px] font-black text-dark dark:border-slate-800 uppercase tracking-widest">Asansör Tipleri</h3>
                    <ul class="space-y-3 normal-case font-medium text-slate-500 dark:text-slate-400">
                      <li><a href="/asansor-tipleri/makine-daireli-asansorler/" class="hover:text-primary transition-colors">Makine Daireli</a></li>
                      <li><a href="/asansor-tipleri/makine-dairesiz-mrl-asansor/" class="hover:text-primary transition-colors">Makine Dairesiz (MRL)</a></li>
                      <li><a href="/asansor-tipleri/hidrolik-asansor/" class="hover:text-primary transition-colors">Hidrolik Asansör</a></li>
                    </ul>
                  </div>
                  <div>
                    <h3 class="mb-4 border-b border-slate-100 pb-2 text-[15px] font-black text-dark dark:border-slate-800 uppercase tracking-widest">Modeller</h3>
                    <ul class="space-y-3 normal-case font-medium text-slate-500 dark:text-slate-400">
                      <li><a href="/modeller/insan-yolcu-asansoru/" class="hover:text-primary transition-colors">İnsan (Yolcu) Asansörü</a></li>
                      <li><a href="/modeller/yuk-asansoru/" class="hover:text-primary transition-colors">Yük Asansörü</a></li>
                      <li><a href="/modeller/monsarj-yemek-asansoru/" class="hover:text-primary transition-colors">Monşarj (Yemek)</a></li>
                      <li><a href="/modeller/panoramik-asansor/" class="hover:text-primary transition-colors">Panoramik Asansör</a></li>
                    </ul>
                  </div>
                  <div>
                    <h3 class="mb-4 border-b border-slate-100 pb-2 text-[15px] font-black text-dark dark:border-slate-800 uppercase tracking-widest">Servisler</h3>
                    <ul class="space-y-3 normal-case font-medium text-slate-500 dark:text-slate-400">
                      <li><a href="/servisler/montaj-hizmetleri/" class="hover:text-primary transition-colors">Montaj</a></li>
                      <li><a href="/servisler/bakim-onarim-hizmetleri/" class="hover:text-primary transition-colors">Bakım & Onarım</a></li>
                      <li><a href="/servisler/revizyon-hizmetleri/" class="hover:text-primary transition-colors">Revizyon</a></li>
                    </ul>
                  </div>
                </div>
              </div>
            </li>
            <li><a href="/iletisim/" class="py-4 transition-colors hover:text-primary">İletişim</a></li>
          </ul>
        </nav>

        <div class="mx-6 h-6 w-px bg-slate-200 dark:bg-slate-800"></div>
        <button id="search-open-btn" aria-label="Ara" class="text-dark-2 transition-colors hover:text-primary">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </button>
        <div class="ml-4"><ThemeToggle /></div>
      </div>

      <!-- Mobile Controls -->
      <div class="flex items-center space-x-1 lg:hidden">
        <button 
          id="search-open-btn-mobile" 
          aria-label="Ara" 
          class="p-2 text-dark-2 transition-colors hover:text-primary"
          data-search-open
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </button>
        <button id="mobile-menu-btn" class="p-2 text-dark-2" aria-label="Menü">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Drawer -->
<div id="mobile-drawer" class="fixed inset-y-0 right-0 z-[60] w-80 translate-x-full bg-white shadow-2xl transition-transform duration-300 dark:bg-slate-950 flex flex-col">
  <div class="flex items-center justify-between border-b border-slate-100 p-6 dark:border-slate-800 flex-shrink-0">
    <Image src={logoImg} alt="KDK Asansör" class="h-8 w-auto" />
    <button id="close-drawer-btn" class="p-2 text-dark-2" aria-label="Kapat">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>
  <div class="p-6 overflow-y-auto flex-grow">
    <ul class="space-y-6 text-sm font-bold uppercase tracking-widest text-dark-2">
      <li><a href="/" class="block border-b border-slate-50 dark:border-slate-900 pb-2 hover:text-primary transition-colors">Anasayfa</a></li>
      <li><a href="/hakkimizda/" class="block border-b border-slate-50 dark:border-slate-900 pb-2 hover:text-primary transition-colors">Hakkımızda</a></li>
      <li>
        <details class="group">
          <summary class="flex justify-between items-center border-b border-slate-50 dark:border-slate-900 pb-2 cursor-pointer hover:text-primary transition-colors">
            Hizmetlerimiz 
            <svg class="w-4 h-4 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div class="mt-4 pl-4 space-y-4 normal-case font-medium text-slate-600 dark:text-slate-400">
            <a href="/asansor-tipleri/" class="block hover:text-primary transition-colors">• Asansör Tipleri</a>
            <a href="/modeller/" class="block hover:text-primary transition-colors">• Modeller</a>
            <a href="/servisler/" class="block hover:text-primary transition-colors">• Servisler</a>
          </div>
        </details>
      </li>
      <li><a href="/iletisim/" class="block border-b border-slate-50 dark:border-slate-900 pb-2 hover:text-primary transition-colors">İletişim</a></li>
    </ul>
  </div>
  
  <!-- Mobile Drawer Bottom Bar (Theme Toggle) -->
  <div class="p-6 border-t border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/50 flex items-center justify-between flex-shrink-0">
    <div class="flex items-center space-x-3 text-slate-500 dark:text-slate-400">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M16.95 16.95l.707.707M7.05 7.05l.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
      </svg>
      <span class="text-[10px] font-black uppercase tracking-[0.2em]">Görünüm Modu</span>
    </div>
    <ThemeToggle direction="up" />
  </div>
</div>

<div id="drawer-overlay" class="fixed inset-0 bg-black/50 z-[55] hidden opacity-0 transition-opacity"></div>

<SearchOverlay />

<script>
  const mainHeader = document.getElementById('main-header');
  const headerInner = document.getElementById('header-inner');
  const headerLogo = document.getElementById('header-logo');

  function handleScroll() {
    if (!mainHeader || !headerInner || !headerLogo) return;
    
    if (window.scrollY > 30) {
      mainHeader.classList.replace('top-5', 'top-0');
      mainHeader.classList.add('shadow-md');
      headerInner.classList.replace('h-24', 'h-16');
      headerLogo.classList.replace('h-14', 'h-10');
    } else {
      mainHeader.classList.replace('top-0', 'top-5');
      mainHeader.classList.remove('shadow-md');
      headerInner.classList.replace('h-16', 'h-24');
      headerLogo.classList.replace('h-10', 'h-14');
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  // Drawer
  const btn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('close-drawer-btn');
  const drawer = document.getElementById('mobile-drawer');
  const overlay = document.getElementById('drawer-overlay');

  btn?.addEventListener('click', () => {
    drawer?.classList.remove('translate-x-full');
    overlay?.classList.remove('hidden');
    setTimeout(() => overlay?.classList.add('opacity-100'), 10);
    document.body.style.overflow = 'hidden';
  });

  const close = () => {
    drawer?.classList.add('translate-x-full');
    overlay?.classList.replace('opacity-100', 'opacity-0');
    setTimeout(() => overlay?.classList.add('hidden'), 300);
    document.body.style.overflow = '';
  };

  closeBtn?.addEventListener('click', close);
  overlay?.addEventListener('click', close);
</script>
