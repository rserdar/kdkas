---
---
<section class="relative isolate overflow-hidden bg-slate-950 pt-28 text-white md:pt-32">
  <div
    class="hero-bg-anim absolute inset-0 -z-30 bg-cover bg-center bg-no-repeat"
    style="background-image: url('/images/hero/main.webp');"
  ></div>
  <div class="absolute inset-0 -z-20 bg-[linear-gradient(90deg,rgba(15,23,42,0.88)_0%,rgba(15,23,42,0.68)_45%,rgba(15,23,42,0.52)_100%)]"></div>
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,rgba(0,82,204,0.35),transparent_35%)]"></div>

  <div class="container mx-auto px-4 pb-20 pt-12 md:pb-24 lg:pb-28">
    <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
      <div class="max-w-3xl">
        <div data-animate="fadeInDown" data-delay="0" class="opacity-0">
          <p class="mb-5 inline-flex rounded-full border border-white/15 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.35em] text-white/80 backdrop-blur">
            Tekin As Asansor
          </p>
        </div>

        <div data-animate="fadeInUp" data-delay="150" class="opacity-0">
          <h1 class="max-w-3xl text-4xl font-bold leading-tight text-white md:text-6xl font-poppins">
            Asansor sistemlerinde profesyonel, guvenli ve uzun omurlu cozumler
          </h1>
        </div>

        <div data-animate="fadeInUp" data-delay="320" class="opacity-0">
          <p class="mt-7 max-w-2xl text-lg leading-8 text-white/78 md:text-xl">
            Tasarim, uretim, montaj, bakim ve revizyon sureclerini ayni kalite anlayisiyla yonetiyor; yapiniza uygun sistemi sahada sorunsuz sekilde hayata geciriyoruz.
          </p>
        </div>

        <div data-animate="fadeInUp" data-delay="460" class="opacity-0">
          <div class="mt-10 flex flex-wrap gap-4">
            <a href="/iletisim/" class="inline-flex items-center rounded-md bg-primary px-7 py-4 text-sm font-semibold uppercase tracking-[0.2em] text-white transition-colors hover:bg-primary-hover">
              Teklif Alin
            </a>
            <a href="/hizmetlerimiz/" class="inline-flex items-center rounded-md border border-white/25 px-7 py-4 text-sm font-semibold uppercase tracking-[0.2em] text-white transition-colors hover:bg-white/10">
              Hizmetlerimiz
            </a>
          </div>
        </div>
      </div>

      <div data-animate="fadeInLeft" data-delay="600" class="opacity-0">
        <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
          <div class="rounded-[1.5rem] border border-white/10 bg-white/10 px-5 py-6 backdrop-blur">
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-white/55">Montaj</p>
            <p class="mt-3 text-base font-medium leading-7 text-white/85">Yeni projelerde estetik ve standartlara uygun uygulama</p>
          </div>
          <div class="rounded-[1.5rem] border border-white/10 bg-white/10 px-5 py-6 backdrop-blur">
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-white/55">Bakim</p>
            <p class="mt-3 text-base font-medium leading-7 text-white/85">Kesintisiz calisma icin planli servis ve hizli mudahale</p>
          </div>
          <div class="rounded-[1.5rem] border border-white/10 bg-white/10 px-5 py-6 backdrop-blur">
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-white/55">Revizyon</p>
            <p class="mt-3 text-base font-medium leading-7 text-white/85">Mevcut sistemleri guncel, guvenli ve verimli hale getirme</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const heroObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;

      const target = entry.target;
      const delay = Number(target.getAttribute('data-delay') || '0');

      setTimeout(() => {
        target.classList.add('animated', target.dataset.animate);
        target.style.opacity = '1';
      }, delay);

      heroObserver.unobserve(target);
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('section [data-animate]:not(.animated)').forEach((element) => {
    element.style.opacity = '0';
    heroObserver.observe(element);
  });
</script>
