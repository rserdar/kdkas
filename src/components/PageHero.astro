---
import bgImg from '../assets/images/hero/arch-plan-1.jpg';

interface Props {
  title: string;
  breadcrumb: {
    label: string;
    url?: string;
  }[];
}
const { title, breadcrumb } = Astro.props;
---
<section class="relative pt-36 pb-20 bg-slate-900 text-white overflow-hidden bg-cover bg-center bg-blend-overlay" style={`background-image: url('${bgImg.src}');`}>
  <div class="container mx-auto px-4 text-center relative z-10">
    <h1 class="text-4xl lg:text-5xl font-bold font-poppins mb-6 animated fadeInUp">{title}</h1>
    <p class="mx-auto mb-5 max-w-3xl text-sm leading-7 text-gray-200 animated fadeInUp" style="--delay: 120ms; animation-delay: 120ms;">
      KDK Asansör, Balıkesir, Edremit ve çevresinde asansör bakım, onarım, montaj ve revizyon hizmetleri sunar.
    </p>

    <div class="flex items-center justify-center space-x-2 text-sm text-gray-300 font-medium tracking-wide animated fadeInUp" style="--delay: 200ms; animation-delay: 200ms;">
      {breadcrumb.map((item, index) => (
        <>
          {index > 0 && <span class="mx-2 text-gray-500">/</span>}
          {item.url ? (
            <a href={item.url} class="hover:text-primary transition-colors">{item.label}</a>
          ) : (
            <span class="text-white">{item.label}</span>
          )}
        </>
      ))}
    </div>
  </div>
</section>
