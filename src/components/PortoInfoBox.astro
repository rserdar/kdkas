---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title?: string;
  subtitle?: string;
  href?: string;
  visualType?: 'icon' | 'ellipse-image' | 'full-logo';
  visualSource?: string | ImageMetadata;
}

const {
  title = '',
  subtitle = '',
  href = '',
  visualType = 'icon',
  visualSource = '',
} = Astro.props;

const isImage = visualSource && typeof visualSource !== 'string';
const isVisualOnly = !title.trim() && !subtitle.trim();
const isValidLink = href && href.trim() !== '' && href.trim() !== '#';
const ElementNode = isValidLink ? 'a' : 'div';
---

<ElementNode href={isValidLink ? href : undefined} class:list={['porto-sicon-box-link group block relative h-full', isVisualOnly ? 'hidden md:block' : '']}>
  <div
    class:list={[
      'relative bg-white h-[300px] p-0 border-r border-b border-gray-100 flex flex-col items-center transition-all duration-300 ease-out hover:shadow-[0_0_40px_rgba(0,0,0,0.1)] group-hover:scale-[0.98] group-hover:z-30 origin-center overflow-hidden',
      {
        'justify-center': !isVisualOnly,
        'justify-start': isVisualOnly,
        'cursor-default pointer-events-none': href === '#',
      },
    ]}
  >
    <div
      class:list={[
        'w-full flex shrink-0 relative z-10 transition-all duration-500 px-4',
        {
          'justify-center items-center h-28 mb-4 mt-10': !isVisualOnly,
          'justify-center items-center h-full': isVisualOnly,
        },
      ]}
    >
      {/* İkon */}
      {visualType === 'icon' && visualSource && (
        <Icon
          name={visualSource as string}
          class:list={[
            'text-dark opacity-90 group-hover:opacity-100 group-hover:text-primary transition-all duration-300 transform group-hover:scale-110',
            { 'w-24 h-24': isVisualOnly, 'w-12 h-12': !isVisualOnly },
          ]}
        />
      )}

      {/* Elips görsel */}
      {visualType === 'ellipse-image' && visualSource && (
        <div
          class:list={[
            'overflow-hidden rounded-[50%] border border-gray-100 shadow-sm group-hover:scale-105 transition-all duration-500 bg-white',
            { 'w-64 h-40': isVisualOnly, 'w-44 h-28': !isVisualOnly },
          ]}
        >
          {isImage
            ? <Image src={visualSource as ImageMetadata} alt={title || 'Görsel'} class="w-full h-full object-cover" />
            : <img src={visualSource as string} alt={title || 'Görsel'} class="w-full h-full object-cover" loading="lazy" decoding="async" />
          }
        </div>
      )}

      {/* Full logo */}
      {visualType === 'full-logo' && visualSource && (
        <div class="flex justify-center items-center group-hover:scale-105 transition-transform duration-500 w-full h-full">
          {isImage
            ? <Image
                src={visualSource as ImageMetadata}
                alt={title || 'Logo'}
                class:list={['object-contain transition-all', { 'max-w-[180px] max-h-[140px]': isVisualOnly, 'max-w-[120px] max-h-20': !isVisualOnly }]}
              />
            : <img
                src={visualSource as string}
                alt={title || 'Logo'}
                loading="lazy"
                decoding="async"
                class:list={['object-contain transition-all', { 'max-w-[180px] max-h-[140px]': isVisualOnly, 'max-w-[120px] max-h-20': !isVisualOnly }]}
              />
          }
        </div>
      )}
    </div>

    {!isVisualOnly && (
      <div class="space-y-3 relative z-10 w-full px-6 text-center pb-8">
        {title.trim() && (
          <h3 class="text-[19px] font-bold text-dark leading-tight group-hover:text-primary transition-colors">
            {title}
          </h3>
        )}
        {subtitle.trim() && (
          <p class="text-[14px] text-[#444] font-medium leading-relaxed max-w-[260px] mx-auto line-clamp-4">
            {subtitle}
          </p>
        )}
      </div>
    )}
  </div>
</ElementNode>

<style>
  .porto-sicon-box-link:hover {
    z-index: 10;
  }
</style>
