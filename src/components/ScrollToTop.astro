      href="https://api.whatsapp.com/send/?phone=905372234382&text=Merhaba%2C+Teklif+almak+istiyorum&type=phone_number&app_absent=0"
      target="_blank"
      rel="noreferrer"
      aria-label="WhatsApp ile iletişime geç"
