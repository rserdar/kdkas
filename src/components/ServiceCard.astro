---
interface Props {
  icon: string;
  title: string;
  description: string;
  href?: string;
  delay?: number;
}
const { icon, title, description, href, delay = 0 } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class="group relative flex flex-col bg-white rounded-2xl border border-slate-100 shadow-sm
         hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden"
  data-animate="fadeInUp"
  data-delay={delay}
>
  <!-- Kırmızı üst çizgi -->
  <div class="h-[3px] w-full bg-gradient-to-r from-primary/40 via-primary to-primary/40
              scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>

  <div class="flex flex-col flex-1 p-7">
    <!-- İkon -->
    <div class="mb-6 w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center text-primary
                group-hover:bg-primary group-hover:text-white transition-all duration-300 shrink-0"
         set:html={icon}>
    </div>

    <!-- Başlık -->
    <h3 class="text-xl font-bold text-dark font-poppins mb-3 group-hover:text-primary transition-colors duration-200">
      {title}
    </h3>

    <!-- Açıklama -->
    <p class="text-gray-500 leading-relaxed text-[15px] flex-1">
      {description}
    </p>

    <!-- Link -->
    {href && (
      <div class="mt-6 pt-5 border-t border-slate-100 flex items-center gap-2 text-sm font-semibold text-slate-400 group-hover:text-primary transition-colors duration-200">
        Detaylı Bilgi
        <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-200"
             fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </div>
    )}
  </div>
</Tag>
