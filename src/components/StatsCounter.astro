---
import { Icon } from 'astro-icon/components';

interface StatItem {
  value: number;
  suffix: string;
  label: string;
  icon: string;
}

interface Props {
  title?: string;
  description?: string;
  stats?: StatItem[];
}

const {
  title = 'Güven veren proje geçmişi ve sahada sürekli destek',
  description = 'Yıllara yayılan uygulama deneyimimiz sayesinde yeni montaj, modernizasyon ve servis süreçlerinde kontrollü, hızlı ve sonuç odaklı çözümler üretiyoruz.',
  stats = [
    { value: 20,   suffix: '+', label: 'Yıllık sektör tecrübesi',        icon: 'mdi:clock-time-eight-outline' },
    { value: 1500, suffix: '+', label: 'Memnun müşteri ve çözüm ortağı', icon: 'mdi:account-group-outline' },
    { value: 2500, suffix: '+', label: 'Tamamlanan uygulama ve revizyon', icon: 'mdi:elevator' },
  ],
} = Astro.props;
---

<section class="relative overflow-hidden bg-dark py-20 text-white md:py-24">
  <div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(255,255,255,0.05),transparent_35%,rgba(204,17,17,0.22))]"></div>
  <div class="container relative mx-auto px-4">
    <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">

      <!-- Sol: Başlık + Açıklama -->
      <div class="stats-reveal opacity-0 translate-y-8">
        <p class="mb-3 font-medium uppercase tracking-[0.35em] text-primary/80">Rakamlarla KDK</p>
        <h2 class="text-3xl font-bold md:text-4xl font-poppins">{title}</h2>
        <p class="mt-6 max-w-xl text-lg leading-8 text-white/75">{description}</p>
      </div>

      <!-- Sağ: İstatistik Kartları -->
      <div class="grid gap-4 sm:grid-cols-3">
        {stats.map((stat, index) => (
          <div
            class="relative flex flex-col items-center p-6 rounded-[1.5rem] border border-white/10 bg-white/5 backdrop-blur overflow-hidden
                   hover:shadow-[0_0_40px_rgba(204,17,17,0.4)] hover:-translate-y-1 transition-all duration-500 group
                   stats-reveal opacity-0 translate-y-8"
            style={`transition-delay: ${200 + index * 120}ms;`}
          >
            <!-- Watermark Icon -->
            <Icon
              name={stat.icon}
              class="absolute -right-3 -bottom-3 w-24 h-24 text-white/[0.06] group-hover:rotate-12 group-hover:scale-110 transition-all duration-700 pointer-events-none"
            />

            <span class="text-[11px] font-bold uppercase tracking-widest text-white/50 mb-4 group-hover:text-primary/80 transition-colors relative z-10 text-center">
              {stat.label}
            </span>

            <div class="flex items-baseline gap-0.5 relative z-10">
              <span
                class="text-5xl font-black text-white tabular-nums counter-value"
                data-target={stat.value}
              >
                0
              </span>
              <span class="text-2xl font-black text-primary">{stat.suffix}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .stats-reveal.revealed {
    opacity: 1;
    transform: translateY(0);
    transition: all 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
</style>

<script>
  function setupStats() {
    const reveals = document.querySelectorAll('.stats-reveal');
    const counters = document.querySelectorAll('.counter-value');

    const animateCounter = (el: HTMLElement) => {
      const target = parseInt(el.getAttribute('data-target') || '0');
      const duration = 2000;
      const stepTime = 20;
      const steps = duration / stepTime;
      const increment = target / steps;
      let current = 0;

      const timer = setInterval(() => {
        current += increment;
        if (current >= target) {
          el.textContent = target.toLocaleString();
          clearInterval(timer);
        } else {
          el.textContent = Math.floor(current).toLocaleString();
        }
      }, stepTime);
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        if (entry.target.classList.contains('stats-reveal')) {
          entry.target.classList.add('revealed');
        }
        if (entry.target.classList.contains('counter-value')) {
          animateCounter(entry.target as HTMLElement);
        }
        observer.unobserve(entry.target);
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    reveals.forEach((el) => observer.observe(el));
    counters.forEach((el) => observer.observe(el));
  }

  document.addEventListener('astro:page-load', setupStats);
  document.addEventListener('DOMContentLoaded', setupStats);
</script>
