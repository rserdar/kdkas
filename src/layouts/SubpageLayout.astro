---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ScrollAnimate from '../components/ScrollAnimate.astro';

interface Props {
  title: string;
  category: string;
  categoryUrl: string;
  image?: string;
}
const { title, category, categoryUrl, image = '/images/hero/arch-plan.jpg' } = Astro.props;

const breadcrumb = [
  { label: 'Anasayfa', url: '/' },
  { label: category, url: categoryUrl },
  { label: title }
];
---
<BaseLayout title={title} description={`${title} hakkında detaylı bilgi.`}>
  <Header slot="header" />

  <PageHero title={title} breadcrumb={breadcrumb} />

  <section class="py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="flex flex-wrap -mx-4">
        <!-- Content -->
        <div class="w-full lg:w-2/3 px-4 mb-12 lg:mb-0">
          <SectionHeading subtitle={category} title={title} />

          <ScrollAnimate animation="fadeInUp" delay={200}>
            <div class="prose prose-lg max-w-none text-gray-600">
              <slot />
            </div>
          </ScrollAnimate>
        </div>

        <!-- Sidebar / Image -->
        <div class="w-full lg:w-1/3 px-4">
          <ScrollAnimate animation="fadeInLeft" delay={300}>
            <div class="sticky top-32 rounded-lg overflow-hidden shadow-xl border border-gray-100">
              <img src={image} alt={title} class="w-full h-auto object-cover" />
              <div class="p-6 bg-light-bg">
                <h4 class="font-bold text-xl mb-4 font-poppins">Destek Gerekli Mi?</h4>
                <p class="text-sm text-gray-600 mb-6">Projeleriniz için uzman ekibimizle iletişime geçin, size en uygun çözümü bulalım.</p>
                <a href="/iletisim/" class="btn-primary-custom w-full justify-center">Bize Ulaşın</a>
              </div>
            </div>
          </ScrollAnimate>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
