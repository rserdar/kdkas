---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollAnimate from '../components/ScrollAnimate.astro';
---
<BaseLayout title="404 - Sayfa Bulunamadı" description="Aradığınız sayfa bulunamadı.">
  <Header slot="header" />

  <section class="min-h-[70vh] flex items-center justify-center py-24 bg-white text-center">
    <div class="container mx-auto px-4">
      <ScrollAnimate animation="fadeInUp">
        <h1 class="text-9xl font-bold text-primary mb-4">404</h1>
        <h2 class="text-3xl lg:text-4xl font-bold text-dark font-poppins mb-8">Aradığınız Sayfa Bulunamadı</h2>
        <p class="text-gray-600 text-lg mb-10 max-w-md mx-auto">
          Aradığınız sayfa silinmiş, ismi değiştirilmiş veya geçici olarak kullanım dışı kalmış olabilir.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/" class="btn-primary-custom">
            Anasayfaya Dön
          </a>
          <a href="/iletisim/" class="btn-outline-custom">
            İletişime Geçin
          </a>
        </div>
      </ScrollAnimate>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
