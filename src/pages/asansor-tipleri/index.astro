---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ServiceTypeCard from '../../components/ServiceTypeCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';

// Import images
import makineDaireliImg from '../../assets/images/asansor-tipleri/makine-daireli.webp';
import makineDairesizImg from '../../assets/images/asansor-tipleri/makine-dairesiz.webp';
import hidrolikImg from '../../assets/images/asansor-tipleri/hidrolik.webp';
import SchemaOrg from '../../components/SchemaOrg.astro';

const breadcrumb = [
  { label: 'Anasayfa', url: '/' },
  { label: 'Hizmetlerimiz', url: '/hizmetlerimiz' },
  { label: 'Asansör Tipleri' }
];

const serviceTypes = [
  {
    title: 'Makine Daireli Asansörler',
    image: makineDaireliImg,
    href: '/asansor-tipleri/makine-daireli-asansorler'
  },
  {
    title: 'Makine Dairesiz (MRL) Asansör',
    image: makineDairesizImg,
    href: '/asansor-tipleri/makine-dairesiz-mrl-asansor'
  },
  {
    title: 'Hidrolik Asansör',
    image: hidrolikImg,
    href: '/asansor-tipleri/hidrolik-asansor'
  }
];
---

<BaseLayout title="Asansör Tipleri" description="Balıkesir ve Edremit'te makine daireli, makine dairesiz (MRL) ve hidrolik asansör sistemleri. Projenize uygun tipi keşfedin.">
  <SchemaOrg slot="head" breadcrumb={breadcrumb} />
  <PageHero title="Asansör Tipleri" breadcrumb={breadcrumb} />

  <section class="py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <SectionHeading 
          subtitle="KDK Asansör" 
          title="Asansör Tipleri"
          centered={true}
        />
        <p class="text-gray-600 max-w-2xl mx-auto mt-6 text-lg" data-animate="fadeInUp" data-delay="200">
          Balıkesir, Edremit ve çevresindeki projeler için bakım, onarım, montaj ve modernizasyon süreçlerine uygun asansör tiplerini burada bulabilirsiniz. Her yapının kullanım senaryosuna göre güvenli, verimli ve uzun ömürlü çözümler sunuyoruz.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {serviceTypes.map((service, index) => (
          <ServiceTypeCard
            title={service.title}
            image={service.image}
            href={service.href}
            delay={300 + (index * 100)}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
