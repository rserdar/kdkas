---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ScrollAnimate from '../../components/ScrollAnimate.astro';
import { Image } from 'astro:assets';

// Import image
import hakkimizdaImg from '../../assets/images/about/kdk-hakkimizda.webp';
import SchemaOrg from '../../components/SchemaOrg.astro';

const breadcrumb = [
  { label: 'Anasayfa', url: '/' },
  { label: 'Hakkımızda' }
];
---
<BaseLayout title="Hakkımızda" description="KDK Asansör hakkında; Balıkesir, Edremit ve çevresinde güven veren asansör sistemleri, bakım ve revizyon hizmetleri.">
  <SchemaOrg slot="head" breadcrumb={breadcrumb} />
  <Header slot="header" />

  <PageHero title="Hakkımızda" breadcrumb={breadcrumb} />

  <section class="bg-white py-24 dark:bg-slate-950">
    <div class="container mx-auto px-4">
      <div class="flex flex-wrap -mx-4 items-center">
        <!-- Content -->
        <div class="w-full lg:w-1/2 px-4 mb-12 lg:mb-0">
          <SectionHeading subtitle="KDK Asansör" title="Güvenilir çözüm ortağınız" />

          <ScrollAnimate animation="fadeInUp" delay={200}>
            <div class="space-y-6 text-lg text-slate-600 dark:text-slate-300">
              <p>
                <strong>Kaliteli asansör sistemleri</strong> ve <strong>müşteri memnuniyeti odaklı hizmet</strong> anlayışını benimseyen <em>KDK Asansör</em>, ilk günkü heyecanıyla yoluna kararlılıkla devam etmektedir.
              </p>
              <p>
                Müşteri gereksinimlerine ve yapı trafiğine uygun çözümler geliştirirken; tasarım, uygulama ve saha koordinasyonunun her aşamasında kalite ve güvenilirliği esas alır.
              </p>
              <p>
                KDK Asansör; Balıkesir, Edremit ve çevresinde asansör sistemleri, montaj, bakım ve revizyon alanlarında güvenilir, erişilebilir ve sürdürülebilir hizmet sunan bir firmadır.
              </p>
            </div>

            <!-- Features list -->
            <ul class="mt-8 space-y-4">
              <li class="flex items-start">
                <svg class="w-6 h-6 text-primary mr-3 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-dark font-medium text-lg">Yenilikçi ve modern tasarımlar</span>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-primary mr-3 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-dark font-medium text-lg">ISO 9001 ve CE kalite sertifikaları</span>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-primary mr-3 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-dark font-medium text-lg">%100 müşteri memnuniyeti garantisi</span>
              </li>
            </ul>
          </ScrollAnimate>
        </div>

        <!-- Image -->
        <div class="w-full lg:w-1/2 px-4">
          <ScrollAnimate animation="fadeInLeft" delay={300}>
            <div class="relative rounded-lg overflow-hidden shadow-2xl">
              <Image src={hakkimizdaImg} alt="KDK Asansör ekibi" class="w-full h-auto object-cover" />
            </div>
          </ScrollAnimate>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="bg-light-bg py-24 dark:bg-slate-900">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="rounded-lg border-t-4 border-primary bg-white p-10 shadow-sm transition-shadow hover:shadow-md dark:bg-slate-950 dark:shadow-black/20">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-6">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <h3 class="text-2xl font-bold text-dark font-poppins mb-4">Misyonumuz</h3>
          <p class="leading-relaxed text-slate-600 dark:text-slate-300">
            Asansör sektöründe güvenli, estetik ve yenilikçi çözümler üreterek yaşam kalitesini artırmak; müşterilerimizin beklentilerini uluslararası standartlara uygun hizmetlerle karşılamak.
          </p>
        </div>

        <div class="rounded-lg border-t-4 border-primary bg-white p-10 shadow-sm transition-shadow hover:shadow-md dark:bg-slate-950 dark:shadow-black/20">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-6">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
          </div>
          <h3 class="text-2xl font-bold text-dark font-poppins mb-4">Vizyonumuz</h3>
          <p class="leading-relaxed text-slate-600 dark:text-slate-300">
            Teknolojik gelişmeleri yakından takip eden, hizmet kalitesini sürekli yükselten ve bölgesinde referans gösterilen asansör markalarından biri olmak.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
