---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ContactForm from '../../components/ContactForm.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';

const breadcrumb = [
  { label: 'Anasayfa', url: '/' },
  { label: 'İletişim' }
];
---
<BaseLayout title="İletişim" description="Kaliteli Hizmetin Adresi — KDK Asansör İletişim Bilgileri.">
  <SchemaOrg slot="head" breadcrumb={breadcrumb} />
  <Header slot="header" />

  <PageHero title="İletişim" breadcrumb={breadcrumb} />

  <section class="py-24 bg-white">
    <div class="container mx-auto px-4">
      <SectionHeading subtitle="KDK Asansör" title="İletişim Bilgilerimiz" centered={true} />

      <!-- Contact Info Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
        <!-- Phone -->
        <div class="text-center p-8 bg-light-bg rounded-lg group hover:shadow-md transition-shadow" data-animate="fadeInUp" data-delay="0">
          <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center text-primary mx-auto mb-6 group-hover:scale-110 transition-transform shadow-sm">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-dark mb-4">Telefon</h3>
          <div class="space-y-2 text-gray-600">
            <div><a href="tel:+905372234382" class="hover:text-primary transition-colors">0 537 223 43 82</a></div>
          </div>
        </div>

        <!-- Company -->
        <div class="text-center p-8 bg-light-bg rounded-lg group hover:shadow-md transition-shadow" data-animate="fadeInUp" data-delay="200">
          <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center text-primary mx-auto mb-6 group-hover:scale-110 transition-transform shadow-sm">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-dark mb-4">Firma Unvanı</h3>
          <div class="text-gray-600">
            KDK ASANSÖR ALİ ŞENTÜRK
          </div>
        </div>

        <!-- Address -->
        <div class="text-center p-8 bg-light-bg rounded-lg group hover:shadow-md transition-shadow" data-animate="fadeInUp" data-delay="400">
          <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center text-primary mx-auto mb-6 group-hover:scale-110 transition-transform shadow-sm">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-dark mb-4">Adres</h3>
          <div class="text-gray-600">
            Eroğlan Mah. 257 Sok. Taşkın Apt. No:2A<br/>Edremit Balıkesir
          </div>
        </div>
      </div>

      <!-- Form & Map -->
      <div class="flex flex-wrap -mx-4">
        <!-- Form -->
        <div class="w-full lg:w-1/2 px-4 mb-12 lg:mb-0" data-animate="fadeInLeft">
          <h3 class="text-2xl font-bold text-dark mb-8 font-poppins">Bize Mesaj Gönderin</h3>
          <ContactForm />
        </div>

        <!-- Map -->
        <div class="w-full lg:w-1/2 px-4" data-animate="fadeInRight">
          <div class="h-full min-h-[400px] rounded-lg overflow-hidden shadow-sm">
            <iframe
              src="https://www.google.com/maps?q=Eroglan%20Mah.%20257%20Sok.%20Taskin%20Apt.%20No%3A2A%20Edremit%20Balikesir&output=embed"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              title="KDK Asansör Konumu"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
