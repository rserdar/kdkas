---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ScrollAnimate from '../components/ScrollAnimate.astro';

const services = [
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>`,
    title: 'Montaj Hizmetleri',
    description: 'Yeni yapılarda ve mevcut binalarda, projeye uygun güvenli ve estetik asansör montaj uygulamaları gerçekleştiriyoruz.',
    href: '/servisler/montaj-hizmetleri/',
    delay: 0
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 6v6l4 2"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`,
    title: 'Bakim ve Onarim',
    description: 'Periyodik kontrol, ariza tespiti ve hizli mudahale ile asansor sistemlerinizin kesintisiz calismasini sagliyoruz.',
    href: '/servisler/bakim-onarim-hizmetleri/',
    delay: 150
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 4v5h5"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M20 20v-5h-5"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5.636 18.364A9 9 0 0018.364 5.636M18.364 18.364A9 9 0 015.636 5.636"></path></svg>`,
    title: 'Revizyon Hizmetleri',
    description: 'Eskiyen sistemleri modern standartlara tasiyor, enerji verimliligi ve kullanim guvenligini yukseltiyoruz.',
    href: '/servisler/revizyon-hizmetleri/',
    delay: 300
  }
];

const solutionGroups = [
  {
    eyebrow: 'Asansor Tipleri',
    title: 'Yapiya uygun teknik cozum',
    text: 'Makine daireli, makine dairesiz MRL ve hidrolik sistemler arasindan projenizin trafigine ve mekan kosullarina en uygun alternatifi belirliyoruz.',
    href: '/asansor-tipleri/',
    image: '/images/makinadairesiz-scaled-1.webp'
  },
  {
    eyebrow: 'Asansor Modelleri',
    title: 'Kullanim senaryosuna gore modelleme',
    text: 'Yolcu, yuk, monsarj, sedye, panoramik ve arac asansoru gibi farkli kullanim alanlari icin ozel uygulamalar sunuyoruz.',
    href: '/modeller/',
    image: '/images/yuk_asansoru01.webp'
  },
  {
    eyebrow: 'Servis Agi',
    title: 'Teslim sonrasi da ayni titizlik',
    text: 'Montaj sonrasinda bakim, onarim ve modernizasyon sureclerini tek merkezden yoneterek sureklilik sagliyoruz.',
    href: '/servisler/',
    image: '/images/elevator-repair.png'
  }
];

const highlights = [
  'ISO 9001 kalite yonetim anlayisi',
  'CE standartlarina uygun uretim ve uygulama',
  'Projeye ozel tasarim, imalat ve saha montaji',
  'Aksama durumlarinda hizli servis destegi'
];

const trustPoints = [
  { value: '20+', label: 'Yillik sektor tecrubesi' },
  { value: '1500+', label: 'Memnun musteri ve cozum ortagi' },
  { value: '2500+', label: 'Tamamlanan uygulama ve revizyon' }
];

const process = [
  {
    step: '01',
    title: 'Kesif ve ihtiyac analizi',
    text: 'Yapinizin trafigi, kuyu olculeri ve kullanim hedefleri degerlendirilir.'
  },
  {
    step: '02',
    title: 'Projelendirme ve uretim',
    text: 'Sisteme uygun kabin, mekanik ekipman ve guvenlik bilesenleri belirlenir.'
  },
  {
    step: '03',
    title: 'Montaj ve devreye alma',
    text: 'Saha ekibimiz kurulumu tamamlar, testler yapilir ve sistem teslim edilir.'
  }
];

const testimonials = [
  {
    quote: 'Teknik detaylara hakim, zamaninda teslimat yapan ve sahada cozum ureten bir ekip ile calistik.',
    author: 'Proje Uygulama Sureci',
    role: 'Kurumsal musteri deneyimi'
  },
  {
    quote: 'Bakim ve ariza sureclerinde hizli donus almamiz isletmemiz icin buyuk avantaj sagladi.',
    author: 'Bakim Onarim Hizmeti',
    role: 'Surekli servis destegi'
  }
];
---

<BaseLayout
  title="Anasayfa"
  description="Tekin As Asansor; asansor montaj, bakim, onarim ve revizyon sureclerinde profesyonel cozumler sunar."
>
  <Header slot="header" />

  <HeroSection />

  <section class="relative overflow-hidden bg-white py-20 md:py-24">
    <div class="absolute left-0 top-0 h-full w-full bg-[radial-gradient(circle_at_top_left,rgba(0,82,204,0.08),transparent_35%)]"></div>
    <div class="absolute -left-24 top-10 hidden h-72 w-72 rounded-full bg-primary/6 blur-3xl lg:block"></div>
    <div class="container relative mx-auto px-4">
      <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
        <div>
          <ScrollAnimate animation="fadeInUp">
            <p class="mb-4 font-medium uppercase tracking-[0.35em] text-primary">Tekin As Asansor</p>
            <h2 class="max-w-2xl text-4xl font-bold leading-tight text-dark md:text-5xl font-poppins">
              Guvenli, modern ve uzun omurlu asansor sistemleri icin uctan uca hizmet
            </h2>
            <div class="mt-6 h-px w-24 bg-primary divider-anim"></div>
            <div class="mt-8 space-y-5 text-lg leading-8 text-slate-600">
              <p>
                "Kaliteli Asansor Kabin Uretimi" ve "Her Zaman Musteri Memnuniyeti" anlayisiyla hareket eden firmamiz, tasarimdan montaja kadar tum surecleri kendi kalite cizgisiyle yonetir.
              </p>
              <p>
                ISO 9001 kalite yonetim sistemi ve CE standartlarina uygun uygulamalarimizla konut, ticari yapi ve endustriyel projelerde guvenilir cozumler sunuyoruz.
              </p>
            </div>
          </ScrollAnimate>

          <ScrollAnimate animation="fadeInUp" delay={120}>
            <div class="mt-10 flex flex-wrap items-center gap-4">
              <a href="/iletisim/" class="btn-primary-custom px-7 py-4 text-base">
                Projenizi Konusalim
              </a>
              <a href="/hizmetlerimiz/" class="btn-outline-custom px-7 py-4 text-base">
                Hizmetlerimizi Inceleyin
              </a>
            </div>
          </ScrollAnimate>

          <ScrollAnimate animation="fadeInUp" delay={220}>
            <div class="mt-10 grid gap-4 sm:grid-cols-2">
              {highlights.map((item) => (
                <div class="flex items-start gap-3 rounded-2xl border border-slate-200 bg-slate-50/70 px-4 py-4">
                  <div class="mt-1 flex h-7 w-7 flex-none items-center justify-center rounded-full bg-primary/10 text-primary">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                  </div>
                  <p class="text-sm font-medium leading-6 text-slate-700">{item}</p>
                </div>
              ))}
            </div>
          </ScrollAnimate>
        </div>

        <div>
          <ScrollAnimate animation="fadeInLeft" delay={160}>
            <div class="relative">
              <div class="absolute -right-6 -top-6 hidden h-24 w-24 rounded-3xl border border-primary/20 bg-primary/10 lg:block"></div>
              <div class="overflow-hidden rounded-[2rem] bg-slate-100 shadow-[0_28px_80px_-32px_rgba(15,23,42,0.4)]">
                <img
                  src="/images/pexels-cottonbro-studio-8453040-scaled-1.webp"
                  alt="Tekin As Asansor uretim ve uygulama"
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              </div>
              <div class="absolute -bottom-6 left-4 right-4 rounded-[1.5rem] border border-white/70 bg-white/90 p-5 shadow-xl backdrop-blur md:left-8 md:right-auto md:w-72">
                <p class="text-xs font-semibold uppercase tracking-[0.3em] text-primary">Hizli Iletisim</p>
                <p class="mt-3 text-lg font-semibold text-dark">Uzman ekibimiz projenize uygun sistemi birlikte planlasin.</p>
                <a href="tel:+902326166910" class="mt-4 inline-flex text-base font-bold text-dark transition-colors hover:text-primary">
                  0232 616 69 10
                </a>
              </div>
            </div>
          </ScrollAnimate>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-light-bg py-20 md:py-24">
    <div class="container mx-auto px-4">
      <div class="mb-14 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <ScrollAnimate animation="fadeInDown" class="max-w-2xl">
          <p class="mb-3 font-medium uppercase tracking-[0.35em] text-primary">Deneyimli Kadromuzla</p>
          <h2 class="text-3xl font-bold text-dark md:text-4xl font-poppins">Sundugumuz hizmetler</h2>
          <p class="mt-5 text-lg leading-8 text-slate-600">
            Projeye ozel planlama, sahada dikkatli uygulama ve teslim sonrasi sureklilik ile tum asansor surecini tek cati altinda yonetiyoruz.
          </p>
        </ScrollAnimate>
        <ScrollAnimate animation="fadeInLeft" delay={140}>
          <a href="/servisler/" class="inline-flex items-center font-semibold text-primary transition-colors hover:text-primary-hover">
            Tum servisleri gor
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        </ScrollAnimate>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3">
        {services.map((service) => <ServiceCard {...service} />)}
      </div>
    </div>
  </section>

  <section class="bg-white py-20 md:py-24">
    <div class="container mx-auto px-4">
      <div class="mb-14 max-w-3xl">
        <ScrollAnimate animation="fadeInUp">
          <p class="mb-3 font-medium uppercase tracking-[0.35em] text-primary">Cozum Basliklari</p>
          <h2 class="text-3xl font-bold text-dark md:text-4xl font-poppins">Farkli yapilar icin dogru sistem kurgusu</h2>
          <p class="mt-5 text-lg leading-8 text-slate-600">
            Yapi tipine, yogunluga ve kullanim amacina gore farkli teknik secenekleri bir araya getiriyor; performans ile estetik arasinda dengeli bir cozum olusturuyoruz.
          </p>
        </ScrollAnimate>
      </div>

      <div class="grid gap-8 lg:grid-cols-3">
        {solutionGroups.map((item, index) => (
          <ScrollAnimate animation="fadeInUp" delay={index * 130}>
            <article class="group overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-[0_20px_60px_-40px_rgba(15,23,42,0.5)] transition-transform duration-300 hover:-translate-y-1">
              <div class="aspect-[16/11] overflow-hidden">
                <img src={item.image} alt={item.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
              </div>
              <div class="p-7">
                <p class="text-xs font-semibold uppercase tracking-[0.3em] text-primary">{item.eyebrow}</p>
                <h3 class="mt-3 text-2xl font-bold leading-tight text-dark font-poppins">{item.title}</h3>
                <p class="mt-4 text-base leading-7 text-slate-600">{item.text}</p>
                <a href={item.href} class="mt-6 inline-flex items-center font-semibold text-dark transition-colors hover:text-primary">
                  Detayli incele
                  <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                  </svg>
                </a>
              </div>
            </article>
          </ScrollAnimate>
        ))}
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-dark py-20 text-white md:py-24">
    <div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(255,255,255,0.05),transparent_35%,rgba(0,82,204,0.22))]"></div>
    <div class="container relative mx-auto px-4">
      <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
        <ScrollAnimate animation="fadeInUp">
          <p class="mb-3 font-medium uppercase tracking-[0.35em] text-primary/80">Rakamlarla Tekin As</p>
          <h2 class="text-3xl font-bold md:text-4xl font-poppins">Guven veren proje gecmisi ve sahada surekli destek</h2>
          <p class="mt-6 max-w-xl text-lg leading-8 text-white/75">
            Yillara yayilan uygulama deneyimimiz sayesinde yeni montaj, modernizasyon ve servis sureclerinde kontrollu, hizli ve olculu cozumler uretiyoruz.
          </p>
        </ScrollAnimate>

        <div class="grid gap-4 sm:grid-cols-3">
          {trustPoints.map((point, index) => (
            <ScrollAnimate animation="fadeInUp" delay={index * 140}>
              <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-6 backdrop-blur">
                <div class="counter text-5xl font-bold text-white" data-target={point.value.replace('+', '')}>0</div>
                <p class="mt-4 text-sm uppercase tracking-[0.25em] text-white/60">{point.label}</p>
              </div>
            </ScrollAnimate>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-light-bg py-20 md:py-24">
    <div class="container mx-auto px-4">
      <div class="mb-14 max-w-3xl">
        <ScrollAnimate animation="fadeInUp">
          <p class="mb-3 font-medium uppercase tracking-[0.35em] text-primary">Calisma Yaklasimimiz</p>
          <h2 class="text-3xl font-bold text-dark md:text-4xl font-poppins">Sureci sade, kontrollu ve seffaf yonetiyoruz</h2>
        </ScrollAnimate>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        {process.map((item, index) => (
          <ScrollAnimate animation="fadeInUp" delay={index * 120}>
            <div class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
              <div class="flex items-center justify-between">
                <span class="text-5xl font-bold leading-none text-primary/15">{item.step}</span>
                <span class="h-px w-16 bg-primary/30"></span>
              </div>
              <h3 class="mt-8 text-2xl font-bold text-dark font-poppins">{item.title}</h3>
              <p class="mt-4 text-base leading-7 text-slate-600">{item.text}</p>
            </div>
          </ScrollAnimate>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-20 md:py-24">
    <div class="container mx-auto px-4">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <ScrollAnimate animation="fadeInUp">
          <p class="mb-3 font-medium uppercase tracking-[0.35em] text-primary">Musteri Yaklasimi</p>
          <h2 class="text-3xl font-bold text-dark md:text-4xl font-poppins">Kaliteyi sadece urunde degil, iletisimde de surduruyoruz</h2>
          <p class="mt-6 max-w-xl text-lg leading-8 text-slate-600">
            Her projede teknik yeterlilik kadar dogru iletisime ve zamaninda geri donuse onem veriyoruz. Bu anlayis teslim sonrasinda da devam eder.
          </p>
          <div class="mt-8 rounded-[1.5rem] bg-slate-900 p-7 text-white">
            <p class="text-sm uppercase tracking-[0.3em] text-white/55">Iletisim</p>
            <a href="tel:+905322052478" class="mt-4 block text-3xl font-bold transition-colors hover:text-primary">0532 205 24 78</a>
            <p class="mt-3 max-w-sm text-base leading-7 text-white/70">
              Projeniz icin teklif, kesif veya teknik gorusme talebinizi bize dogrudan iletebilirsiniz.
            </p>
          </div>
        </ScrollAnimate>

        <div class="grid gap-6 md:grid-cols-2">
          {testimonials.map((item, index) => (
            <ScrollAnimate animation="fadeInUp" delay={index * 140}>
              <blockquote class="flex h-full flex-col rounded-[1.75rem] border border-slate-200 bg-slate-50 p-8">
                <div class="mb-6 text-4xl leading-none text-primary">"</div>
                <p class="flex-1 text-lg leading-8 text-slate-700">{item.quote}</p>
                <footer class="mt-8 border-t border-slate-200 pt-5">
                  <div class="font-semibold text-dark">{item.author}</div>
                  <div class="mt-1 text-sm uppercase tracking-[0.2em] text-slate-500">{item.role}</div>
                </footer>
              </blockquote>
            </ScrollAnimate>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-[linear-gradient(135deg,#0f172a_0%,#111827_55%,#0052cc_140%)] py-20 text-white md:py-24">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.12),transparent_30%)]"></div>
    <div class="container relative mx-auto px-4">
      <ScrollAnimate animation="fadeInUp">
        <div class="rounded-[2rem] border border-white/10 bg-white/5 px-8 py-10 backdrop-blur md:px-12 md:py-14">
          <div class="flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
            <div class="max-w-2xl">
              <p class="mb-3 font-medium uppercase tracking-[0.35em] text-primary/80">Bir sonraki adim</p>
              <h2 class="text-3xl font-bold md:text-4xl font-poppins">Asansor projeniz icin dogru sistemi birlikte belirleyelim</h2>
              <p class="mt-5 text-lg leading-8 text-white/75">
                Yeni proje, modernizasyon ya da bakim plani fark etmeksizin ihtiyaciniza uygun cozum icin bizimle iletisime gecin.
              </p>
            </div>
            <div class="flex flex-wrap gap-4">
              <a href="/iletisim/" class="inline-flex items-center rounded-md bg-white px-7 py-4 font-semibold text-dark transition-colors hover:bg-slate-100">
                Iletisime Gecin
              </a>
              <a href="/hizmetlerimiz/" class="inline-flex items-center rounded-md border border-white/25 px-7 py-4 font-semibold text-white transition-colors hover:bg-white/10">
                Hizmetleri Kesfedin
              </a>
            </div>
          </div>
        </div>
      </ScrollAnimate>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const counters = document.querySelectorAll('.counter');
  const speed = 120;

  const counterObserver = new IntersectionObserver((entries, observer) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;

      const counter = entry.target;
      const target = Number(counter.getAttribute('data-target') || '0');

      const updateCount = () => {
        const count = Number(counter.textContent || '0');
        const increment = Math.max(1, Math.ceil(target / speed));

        if (count < target) {
          counter.textContent = String(Math.min(target, count + increment));
          requestAnimationFrame(updateCount);
        } else {
          counter.textContent = `${target}+`;
        }
      };

      updateCount();
      observer.unobserve(counter);
    });
  }, { threshold: 0.35 });

  counters.forEach((counter) => counterObserver.observe(counter));
</script>
