---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ScrollAnimate from '../components/ScrollAnimate.astro';

// SVG Icons for services
const icons = {
  montaj: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>`,
  bakim: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`,
  revizyon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>`
};
---

<BaseLayout title="Anasayfa" description="Asansör sistemlerinde profesyonel çözümler.">
  <Header slot="header" />

  <HeroSection />

  <!-- Section 2: Company Intro -->
  <section class="py-24 relative overflow-hidden bg-white">
    <!-- Decorative background image -->
    <div class="absolute top-0 left-0 w-1/3 h-full bg-no-repeat bg-contain opacity-10 pointer-events-none -z-10" style="background-image: url('/images/hero/arch-plan.jpg');"></div>

    <div class="container mx-auto px-4">
      <div class="flex flex-wrap -mx-4 items-center">
        <!-- Text Content -->
        <div class="w-full lg:w-1/2 px-4 mb-12 lg:mb-0">
          <ScrollAnimate animation="fadeInUp">
            <h2 class="text-3xl lg:text-4xl font-bold text-dark font-poppins mb-2 uppercase">Tekin As Asansör</h2>
            <div class="h-1 bg-primary w-0 mb-8 divider-anim"></div>

            <p class="text-gray-600 text-lg leading-relaxed mb-6">
              "Kaliteli Asansör Kabin Üretimi" ve "Her Zaman Müşteri Memnuniyeti" politikalarını ilke edinen firmamız, uzun yılların verdiği deneyimle sektörde öncü olmaya devam etmektedir.
            </p>
            <p class="text-gray-600 mb-8">
              ISO 9001 kalite yönetim sistemi ve CE sertifikalarımızla, standartlara uygun, güvenli ve modern asansör çözümleri sunuyoruz. İmalattan montaja, bakımdan revizyona kadar asansörünüzün tüm süreçlerinde yanınızdayız.
            </p>

            <div class="flex flex-wrap items-center gap-6">
              <a href="/iletisim/" class="btn-primary-custom">
                İletişime Geçin
              </a>
              <div class="flex items-center text-dark font-medium">
                <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center mr-3 text-primary">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                </div>
                <div>
                  <div class="text-xs text-gray-500">Bizi şimdi arayın</div>
                  <a href="tel:+902326166910" class="hover:text-primary transition-colors">0232 616 69 10</a>
                </div>
              </div>
            </div>
          </ScrollAnimate>
        </div>

        <!-- Image -->
        <div class="w-full lg:w-1/2 px-4 relative">
          <ScrollAnimate animation="fadeInLeft" delay={200}>
            <div class="relative rounded-lg overflow-hidden shadow-2xl">
              <!-- Using standard img tag with tailwind classes for responsiveness -->
              <img src="/images/hero/main.webp" alt="Asansör Üretim ve Montajı" class="w-full h-auto object-cover aspect-[4/3]" loading="lazy" />
              <!-- Floating badge -->
              <div class="absolute bottom-6 left-6 bg-white p-4 rounded shadow-lg flex items-center gap-4">
                <div class="text-4xl font-bold text-primary">20+</div>
                <div class="text-sm font-medium text-dark leading-tight">Yıllık<br/>Tecrübe</div>
              </div>
            </div>
          </ScrollAnimate>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Services Grid -->
  <section class="py-24 bg-light-bg">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <ScrollAnimate animation="fadeInDown">
          <div class="text-primary font-medium tracking-widest uppercase text-sm mb-2">Deneyimli Kadromuzla</div>
          <h2 class="text-3xl lg:text-4xl font-bold text-dark font-poppins mb-6">Sunduğumuz Hizmetler</h2>
          <p class="text-gray-600">Uzman teknik elemanlarımız, deneyimli mühendis kadromuz ile her türlü asansör sistemlerinin kurulumu, bakımı ve revizyonu konularında hizmet vermekteyiz.</p>
        </ScrollAnimate>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <ServiceCard
          icon={icons.montaj}
          title="Montaj Hizmetleri"
          description="Yeni binalarınız veya mevcut yapılarınız için standartlara tam uyumlu, güvenli ve estetik asansör montaj çözümleri sunuyoruz."
          href="/servisler/montaj-hizmetleri/"
          delay={0}
        />
        <ServiceCard
          icon={icons.bakim}
          title="Bakım & Onarım Hizmetleri"
          description="Asansörlerinizin kesintisiz ve güvenli çalışması için periyodik bakım hizmeti veriyor, olası arızalara 7/24 hızlı müdahale ediyoruz."
          href="/servisler/bakim-onarim-hizmetleri/"
          delay={200}
        />
        <ServiceCard
          icon={icons.revizyon}
          title="Revizyon Hizmetleri"
          description="Eski asansörlerinizi güncel standartlara uygun, enerji verimli ve modern sistemlerle yeniliyoruz."
          href="/servisler/revizyon-hizmetleri/"
          delay={400}
        />
      </div>
    </div>
  </section>

  <!-- Section 4: Counters -->
  <section class="py-20 bg-primary text-white relative">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center divide-y md:divide-y-0 md:divide-x divide-white/20">
        <div class="p-4">
          <div class="text-5xl font-bold mb-2 counter" data-target="20">0</div>
          <div class="text-white/80 font-medium uppercase tracking-wider text-sm">Yıllık Tecrübe</div>
        </div>
        <div class="p-4 pt-8 md:pt-4">
          <div class="text-5xl font-bold mb-2 counter" data-target="1500">0</div>
          <div class="text-white/80 font-medium uppercase tracking-wider text-sm">Mutlu Müşteri</div>
        </div>
        <div class="p-4 pt-8 md:pt-4">
          <div class="text-5xl font-bold mb-2 counter" data-target="2500">0</div>
          <div class="text-white/80 font-medium uppercase tracking-wider text-sm">Tamamlanan Proje</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5: Contact CTA -->
  <section class="py-24 bg-dark relative bg-[url('/images/hero/arch-plan.jpg')] bg-cover bg-center bg-blend-overlay bg-black/80 text-center">
    <div class="container mx-auto px-4 relative z-10">
      <ScrollAnimate animation="fadeInUp">
        <h2 class="text-3xl lg:text-5xl font-bold text-white font-poppins mb-6">Projeniz İçin Profesyonel Destek Alın</h2>
        <p class="text-gray-300 text-lg mb-10 max-w-2xl mx-auto">Asansör ihtiyaçlarınız için uzman ekibimizle görüşün. Size en uygun, güvenli ve ekonomik çözümleri sunalım.</p>
        <a href="/iletisim/" class="inline-flex items-center px-8 py-4 bg-white text-dark rounded font-bold hover:bg-primary hover:text-white transition-all duration-300 text-lg">
          Bizimle İletişime Geçin
        </a>
      </ScrollAnimate>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  // Simple Counter Animation logic using IntersectionObserver
  const counters = document.querySelectorAll('.counter');
  const speed = 200; // The lower the slower

  const counterObserver = new IntersectionObserver((entries, observer) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const counter = entry.target as HTMLElement;
        const updateCount = () => {
          const target = +counter.getAttribute('data-target')!;
          const count = +counter.innerText;
          const inc = target / speed;

          if (count < target) {
            counter.innerText = Math.ceil(count + inc).toString();
            setTimeout(updateCount, 1);
          } else {
            counter.innerText = target.toString() + "+";
          }
        };
        updateCount();
        observer.unobserve(counter);
      }
    });
  }, { threshold: 0.5 });

  counters.forEach(counter => {
    counterObserver.observe(counter);
  });
</script>