---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ScrollAnimate from '../components/ScrollAnimate.astro';
import StatsCounter from '../components/StatsCounter.astro';
import { Image } from 'astro:assets';

// Import images
import mainHeroImg from '../assets/images/hero/main.webp';
import mrlImg from '../assets/images/asansor-tipleri/makine-dairesiz.webp';
import yukImg from '../assets/images/asansor-modelleri/yuk-asansoru-1.webp';
import repairImg from '../assets/images/servisler/elevator-repair.png';

const services = [
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>`,
    title: 'Montaj Hizmetleri',
    description: 'Yeni yapılarda ve mevcut binalarda, projeye özel güvenli, estetik ve standartlara uygun asansör montaj uygulamaları gerçekleştiriyoruz.',
    href: '/servisler/montaj-hizmetleri/',
    delay: 0
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 6v6l4 2"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`,
    title: 'Bakım ve Onarım',
    description: 'Periyodik kontrol, arıza tespiti ve hızlı müdahale ile sistemlerinizin güvenli ve kesintisiz çalışmasını sağlıyoruz.',
    href: '/servisler/bakim-onarim-hizmetleri/',
    delay: 150
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 4v5h5"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M20 20v-5h-5"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5.636 18.364A9 9 0 0018.364 5.636M18.364 18.364A9 9 0 015.636 5.636"></path></svg>`,
    title: 'Revizyon Hizmetleri',
    description: 'Eskiyen sistemleri modern standartlara taşıyor; enerji verimliliği, konfor ve kullanım güvenliğini yükseltiyoruz.',
    href: '/servisler/revizyon-hizmetleri/',
    delay: 300
  }
];

const solutionGroups = [
  {
    eyebrow: 'Asansör Tipleri',
    title: 'Yapıya uygun teknik çözüm',
    text: 'Makine daireli, makine dairesiz MRL ve hidrolik sistemler arasından projenizin trafiğine, mimarisine ve kullanım yoğunluğuna en uygun alternatifi belirliyoruz.',
    href: '/asansor-tipleri/',
    image: mrlImg
  },
  {
    eyebrow: 'Asansör Modelleri',
    title: 'Kullanım senaryosuna göre modelleme',
    text: 'Yolcu, yük, monşarj, sedye, panoramik ve araç asansörü gibi farklı kullanım alanları için işlevsel ve uzun ömürlü uygulamalar sunuyoruz.',
    href: '/modeller/',
    image: yukImg
  },
  {
    eyebrow: 'Servis Ağı',
    title: 'Teslim sonrası da aynı titizlik',
    text: 'Montaj sonrasında bakım, onarım ve modernizasyon süreçlerini aynı kalite çizgisinde yöneterek uzun vadeli süreklilik sağlıyoruz.',
    href: '/servisler/',
    image: repairImg
  }
];

const highlights = [
  'ISO 9001 kalite yönetim anlayışı',
  'CE standartlarına uygun üretim ve uygulama',
  'Projeye özel tasarım, imalat ve saha montajı',
  'Aksama durumlarında hızlı servis desteği'
];

const process = [
  {
    step: '01',
    title: 'Keşif ve ihtiyaç analizi',
    text: 'Yapınızın trafiği, kuyu ölçüleri ve kullanım hedefleri değerlendirilir.'
  },
  {
    step: '02',
    title: 'Projelendirme ve üretim',
    text: 'Sisteme uygun kabin, mekanik ekipman ve güvenlik bileşenleri belirlenir.'
  },
  {
    step: '03',
    title: 'Montaj ve devreye alma',
    text: 'Saha ekibimiz kurulumu tamamlar, testler yapılır ve sistem teslim edilir.'
  }
];

const testimonials = [
  {
    quote: 'Teknik detaylara hakim, zamanında teslimat yapan ve sahada çözüm üreten bir ekip ile çalıştık.',
    author: 'Proje Uygulama Süreci',
    role: 'Kurumsal müşteri deneyimi'
  },
  {
    quote: 'Bakım ve arıza süreçlerinde hızlı dönüş almamız işletmemiz için büyük avantaj sağladı.',
    author: 'Bakım Onarım Hizmeti',
    role: 'Sürekli servis desteği'
  }
];
---

<BaseLayout
  title="Asansör Montaj, Bakım ve Revizyon Hizmetleri"
  description="KDK Asansör; Balıkesir, Edremit ve çevresinde asansör montaj, bakım, onarım ve revizyon süreçlerinde profesyonel çözümler sunar. ISO 9001 kalite, CE standartları."
  schemaType="home"
>
  <Header slot="header" />

  <HeroSection />

  <section class="relative overflow-hidden bg-white py-20 md:py-24 dark:bg-slate-950">
    <div class="absolute left-0 top-0 h-full w-full bg-[radial-gradient(circle_at_top_left,rgba(204,17,17,0.08),transparent_35%)]"></div>
    <div class="absolute -left-24 top-10 hidden h-72 w-72 rounded-full bg-primary/6 blur-3xl lg:block"></div>
    <div class="container relative mx-auto px-4">
      <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
        <div>
          <ScrollAnimate animation="fadeInUp">
            <p class="mb-4 font-medium uppercase tracking-[0.35em] text-primary">KDK Asansör</p>
            <h2 class="max-w-2xl text-4xl font-bold leading-tight text-dark md:text-5xl font-poppins">
              Güvenli, modern ve uzun ömürlü asansör sistemleri için uçtan uca hizmet
            </h2>
            <div class="mt-6 h-px w-24 bg-primary divider-anim"></div>
            <div class="mt-8 space-y-5 text-lg leading-8 text-slate-600 dark:text-slate-300">
              <p>
                “Kaliteli Asansör Sistemleri” ve “Her Zaman Müşteri Memnuniyeti” anlayışıyla hareket eden firmamız, tasarımdan montaja kadar tüm süreçleri kendi kalite çizgisiyle yönetir.
              </p>
              <p>
                ISO 9001 kalite yönetim sistemi ve CE standartlarına uygun uygulamalarımızla; Balıkesir, Edremit ve çevresindeki konut, ticari yapı ve endüstriyel projelerde güvenilir çözümler sunuyoruz.
              </p>
            </div>
          </ScrollAnimate>

          <ScrollAnimate animation="fadeInUp" delay={120}>
            <div class="mt-10 flex flex-wrap items-center gap-4">
              <a href="/iletisim/" class="btn-primary-custom px-7 py-4 text-base">
                Projenizi Konuşalım
              </a>
              <a href="/hizmetlerimiz/" class="btn-outline-custom px-7 py-4 text-base">
                Hizmetlerimizi İnceleyin
              </a>
            </div>
          </ScrollAnimate>

          <ScrollAnimate animation="fadeInUp" delay={220}>
            <div class="mt-10 grid gap-4 sm:grid-cols-2">
              {highlights.map((item) => (
                <div class="flex items-start gap-3 rounded-2xl border border-slate-200 bg-slate-50/70 px-4 py-4 dark:border-slate-800 dark:bg-slate-900/70">
                  <div class="mt-1 flex h-7 w-7 flex-none items-center justify-center rounded-full bg-primary/10 text-primary">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                  </div>
                  <p class="text-sm font-medium leading-6 text-slate-700 dark:text-slate-200">{item}</p>
                </div>
              ))}
            </div>
          </ScrollAnimate>
        </div>

        <div>
          <ScrollAnimate animation="fadeInLeft" delay={160}>
            <div class="relative">
              <div class="absolute -right-6 -top-6 hidden h-24 w-24 rounded-3xl border border-primary/20 bg-primary/10 lg:block"></div>
              <div class="overflow-hidden rounded-[2rem] bg-slate-100 shadow-[0_28px_80px_-32px_rgba(15,23,42,0.4)] dark:bg-slate-900">
                <Image
                  src={mainHeroImg}
                  alt="KDK Asansör üretim ve uygulama"
                  class="h-full w-full object-cover"
                />
              </div>
              <div class="absolute -bottom-6 left-4 right-4 rounded-[1.5rem] border border-white/70 bg-white/90 p-5 shadow-xl backdrop-blur md:left-8 md:right-auto md:w-72 dark:border-slate-700 dark:bg-slate-950/85">
                <p class="text-xs font-semibold uppercase tracking-[0.3em] text-primary">Hızlı İletişim</p>
                <p class="mt-3 text-lg font-semibold text-slate-800 dark:text-slate-100">Uzman ekibimiz, yapınıza en uygun sistemi sizinle birlikte planlasın.</p>
                <a href="tel:+905372234382" class="mt-4 inline-flex text-base font-bold text-slate-800 dark:text-slate-100 transition-colors hover:text-primary">
                  0 537 223 43 82
                </a>
              </div>
            </div>
          </ScrollAnimate>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-light-bg py-20 md:py-24 dark:bg-slate-900">
    <div class="container mx-auto px-4">
      <div class="mb-14 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <ScrollAnimate animation="fadeInDown" class="max-w-2xl">
          <p class="mb-3 font-medium uppercase tracking-[0.35em] text-primary">Deneyimli Kadromuzla</p>
          <h2 class="text-3xl font-bold text-dark md:text-4xl font-poppins">Sunduğumuz hizmetler</h2>
          <p class="mt-5 text-lg leading-8 text-slate-600 dark:text-slate-300">
            Projeye özel planlama, sahada titiz uygulama ve teslim sonrası süreklilik ile tüm asansör sürecini tek çatı altında yönetiyoruz.
          </p>
        </ScrollAnimate>
        <ScrollAnimate animation="fadeInLeft" delay={140}>
          <a href="/servisler/" class="inline-flex items-center font-semibold text-primary transition-colors hover:text-primary-hover">
            Tüm servisleri gör
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        </ScrollAnimate>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3">
        {services.map((service) => <ServiceCard {...service} />)}
      </div>
    </div>
  </section>

  <section class="bg-white py-20 md:py-24 dark:bg-slate-950">
    <div class="container mx-auto px-4">
      <div class="mb-14 max-w-3xl">
        <ScrollAnimate animation="fadeInUp">
          <p class="mb-3 font-medium uppercase tracking-[0.35em] text-primary">Çözüm Başlıkları</p>
          <h2 class="text-3xl font-bold text-dark md:text-4xl font-poppins">Farklı yapılar için doğru sistem kurgusu</h2>
          <p class="mt-5 text-lg leading-8 text-slate-600 dark:text-slate-300">
            Yapı tipine, yoğunluğa ve kullanım amacına göre farklı teknik seçenekleri bir araya getiriyor; performans ile estetik arasında dengeli bir çözüm oluşturuyoruz.
          </p>
        </ScrollAnimate>
      </div>

      <div class="grid gap-8 lg:grid-cols-3">
        {solutionGroups.map((item, index) => (
          <ScrollAnimate animation="fadeInUp" delay={index * 130}>
            <article class="group overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-[0_20px_60px_-40px_rgba(15,23,42,0.5)] transition-transform duration-300 hover:-translate-y-1 dark:border-slate-800 dark:bg-slate-900">
              <div class="aspect-[16/11] overflow-hidden">
                <Image src={item.image} alt={item.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
              </div>
              <div class="p-7">
                <p class="text-xs font-semibold uppercase tracking-[0.3em] text-primary">{item.eyebrow}</p>
                <h3 class="mt-3 text-2xl font-bold leading-tight text-dark font-poppins">{item.title}</h3>
                <p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-300">{item.text}</p>
                <a href={item.href} class="mt-6 inline-flex items-center font-semibold text-dark transition-colors hover:text-primary">
                  Detaylı incele
                  <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                  </svg>
                </a>
              </div>
            </article>
          </ScrollAnimate>
        ))}
      </div>
    </div>
  </section>

  <StatsCounter />

  <section class="bg-light-bg py-20 md:py-24 dark:bg-slate-900">
    <div class="container mx-auto px-4">
      <div class="mb-14 max-w-3xl">
        <ScrollAnimate animation="fadeInUp">
          <p class="mb-3 font-medium uppercase tracking-[0.35em] text-primary">Çalışma Yaklaşımımız</p>
          <h2 class="text-3xl font-bold text-dark md:text-4xl font-poppins">Süreci sade, kontrollü ve şeffaf yönetiyoruz</h2>
        </ScrollAnimate>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        {process.map((item, index) => (
          <ScrollAnimate animation="fadeInUp" delay={index * 120}>
            <div class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-slate-950">
              <div class="flex items-center justify-between">
                <span class="text-5xl font-bold leading-none text-primary/15">{item.step}</span>
                <span class="h-px w-16 bg-primary/30"></span>
              </div>
              <h3 class="mt-8 text-2xl font-bold text-dark font-poppins">{item.title}</h3>
              <p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-300">{item.text}</p>
            </div>
          </ScrollAnimate>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-20 md:py-24 dark:bg-slate-950">
    <div class="container mx-auto px-4">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <ScrollAnimate animation="fadeInUp">
          <p class="mb-3 font-medium uppercase tracking-[0.35em] text-primary">Müşteri Yaklaşımı</p>
          <h2 class="text-3xl font-bold text-dark md:text-4xl font-poppins">Kaliteyi sadece üründe değil, iletişimde de sürdürüyoruz</h2>
          <p class="mt-6 max-w-xl text-lg leading-8 text-slate-600 dark:text-slate-300">
            Her projede teknik yeterlilik kadar açık iletişime, zamanında geri dönüşe ve sürdürülebilir hizmet anlayışına önem veriyoruz. Bu yaklaşım teslim sonrasında da devam eder.
          </p>
          <div class="mt-8 rounded-[1.5rem] bg-slate-900 p-7 text-white">
            <p class="text-sm uppercase tracking-[0.3em] text-white/55">İletişim</p>
            <a href="tel:+905372234382" class="mt-4 block text-3xl font-bold transition-colors hover:text-primary">0 537 223 43 82</a>
            <p class="mt-3 max-w-sm text-base leading-7 text-white/70">
              Balıkesir, Edremit ve çevresindeki projeleriniz için teklif, keşif veya teknik görüşme talebinizi bize doğrudan iletebilirsiniz.
            </p>
          </div>
        </ScrollAnimate>

        <div class="grid gap-6 md:grid-cols-2">
          {testimonials.map((item, index) => (
            <ScrollAnimate animation="fadeInUp" delay={index * 140}>
              <blockquote class="flex h-full flex-col rounded-[1.75rem] border border-slate-200 bg-slate-50 p-8 dark:border-slate-800 dark:bg-slate-900">
                <div class="mb-6 text-4xl leading-none text-primary">"</div>
                <p class="flex-1 text-lg leading-8 text-slate-700 dark:text-slate-200">{item.quote}</p>
                <footer class="mt-8 border-t border-slate-200 pt-5 dark:border-slate-800">
                  <div class="font-semibold text-dark">{item.author}</div>
                  <div class="mt-1 text-sm uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">{item.role}</div>
                </footer>
              </blockquote>
            </ScrollAnimate>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-[linear-gradient(135deg,#0f172a_0%,#111827_55%,#cc1111_140%)] py-20 text-white md:py-24">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.12),transparent_30%)]"></div>
    <div class="container relative mx-auto px-4">
      <ScrollAnimate animation="fadeInUp">
        <div class="rounded-[2rem] border border-white/10 bg-white/5 px-8 py-10 backdrop-blur md:px-12 md:py-14">
          <div class="flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
            <div class="max-w-2xl">
              <p class="mb-3 font-medium uppercase tracking-[0.35em] text-primary/80">Bir sonraki adım</p>
              <h2 class="text-3xl font-bold md:text-4xl font-poppins">Asansör projeniz için doğru sistemi birlikte belirleyelim</h2>
              <p class="mt-5 text-lg leading-8 text-white/75">
                Yeni proje, modernizasyon ya da bakım planı fark etmeksizin; Balıkesir, Edremit ve çevresinde ihtiyacınıza uygun çözüm için bizimle iletişime geçin.
              </p>
            </div>
            <div class="flex flex-wrap gap-4">
              <a href="/iletisim/" class="inline-flex items-center rounded-md bg-white px-7 py-4 font-semibold text-slate-900 transition-colors hover:bg-slate-100">
                İletişime Geçin
              </a>
              <a href="/hizmetlerimiz/" class="inline-flex items-center rounded-md border border-white/25 px-7 py-4 font-semibold text-white transition-colors hover:bg-white/10">
                Hizmetleri Keşfedin
              </a>
            </div>
          </div>
        </div>
      </ScrollAnimate>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
