---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ServiceTypeCard from '../../components/ServiceTypeCard.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';

import insanImg     from '../../assets/images/asansor-modelleri/insan-asansoru.webp';
import yukImg       from '../../assets/images/asansor-modelleri/yuk-asansoru-1.webp';
import monsarjImg   from '../../assets/images/asansor-modelleri/monsarj-yemek-asansoru.webp';
import sedyeImg     from '../../assets/images/asansor-modelleri/sedye-asansoru.webp';
import panoramikImg from '../../assets/images/asansor-modelleri/panoramik-asansor.webp';
import aracImg      from '../../assets/images/asansor-modelleri/arac1.webp';
import engelliImg   from '../../assets/images/asansor-modelleri/97d1662a.webp';

const breadcrumb = [
  { label: 'Anasayfa', url: '/' },
  { label: 'Hizmetlerimiz', url: '/hizmetlerimiz/' },
  { label: 'Asansör Modelleri' }
];

const models = [
  { title: 'İnsan (Yolcu) Asansörü',   image: insanImg,     href: '/modeller/insan-yolcu-asansoru/' },
  { title: 'Yük Asansörü',             image: yukImg,       href: '/modeller/yuk-asansoru/' },
  { title: 'Monşarj (Yemek) Asansörü', image: monsarjImg,   href: '/modeller/monsarj-yemek-asansoru/' },
  { title: 'Sedye Asansörleri',        image: sedyeImg,     href: '/modeller/sedye-asansorleri/' },
  { title: 'Panoramik Asansör',        image: panoramikImg, href: '/modeller/panoramik-asansor/' },
  { title: 'Araç Asansörü',            image: aracImg,      href: '/modeller/arac-asansoru/' },
  { title: 'Engelli Platformları',     image: engelliImg,   href: '/modeller/engelli-platformlari/' },
];
---

<BaseLayout
  title="Asansör Modelleri"
  description="KDK Asansör modelleri: Balıkesir, Edremit ve çevresi için yolcu, yük, monşarj, sedye, panoramik, araç asansörleri ve engelli platformları."
>
  <SchemaOrg slot="head" breadcrumb={breadcrumb} />
  <Header slot="header" />

  <PageHero title="Asansör Modelleri" breadcrumb={breadcrumb} />

  <section class="py-24 bg-white dark:bg-slate-950">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <SectionHeading subtitle="Ürün Gruplarımız" title="Asansör Modelleri" centered={true} />
        <p class="text-gray-600 dark:text-slate-300 max-w-2xl mx-auto mt-6 text-lg" data-animate="fadeInUp" data-delay="100">
          Konutlardan ticari yapılara, hastanelerden endüstriyel tesislere kadar her kullanım amacına uygun asansör modeli sunuyoruz.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {models.map((model, index) => (
          <ServiceTypeCard
            title={model.title}
            image={model.image}
            href={model.href}
            delay={index * 80}
          />
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
